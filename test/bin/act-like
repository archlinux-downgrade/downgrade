#!/usr/bin/env bash
program="$1"
shift
base="${program##*/}"

fixtures="$SRCDIR/test/fixtures/$base/$(echo "$*" | md5sum | cut -d ' ' -f 1)"

if [[ ! -d "$fixtures" ]]; then
  if ((FIXTURES_NO_RECORD)); then
    cat >&2 <<EOM
The program $program is mocked and no mock was found for the arguments:

  $program $*

Since FIXTURES_NO_RECORD is set, we are erroring instead of recording the output
of the program to use in future calls. If this call is expected and should be
mocked, run the tests without FIXTURES_NO_RECORD set and commit the resulting
files generated in test/fixtures.

EOM
    exit 100
  fi

  mkdir -p "$fixtures"
  $program "$@" >"$fixtures/stdout" 2>"$fixtures/stderr"
  echo $? >"$fixtures/exit_code"
fi

cat "$fixtures/stdout"
cat "$fixtures/stderr" >&2

read -r exit_code <"$fixtures/exit_code"

exit "$exit_code"
